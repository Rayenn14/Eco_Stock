{
  "expo": {
    "name": "EcoStock2",
    "slug": "EcoStock2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/EcoStockLogo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/EcoStockLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Calculer la distance jusqu'au magasin"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/EcoStockLogo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "favicon": "./assets/images/EcoStockLogo.png"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
